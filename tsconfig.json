{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": [
      "node"
    ],
    "verbatimModuleSyntax": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
