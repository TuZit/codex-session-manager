{
  "name": "@tuzitt/codex-session-manager",
  "version": "0.0.1",
  "description": "A CLI for inspecting and safely managing local Codex sessions.",
  "type": "module",
  "author": "TuZit",
  "license": "MIT",
  "homepage": "https://github.com/TuZit/codex-session-manager#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/TuZit/codex-session-manager.git"
  },
  "bugs": {
    "url": "https://github.com/TuZit/codex-session-manager/issues"
  },
  "bin": {
    "codex-session-manager": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "./node_modules/.bin/tsc -p tsconfig.json",
    "dev": "./node_modules/.bin/tsx src/cli.ts",
    "test": "./node_modules/.bin/vitest run",
    "typecheck": "./node_modules/.bin/tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "codex",
    "cli",
    "sessions",
    "openai",
    "tui"
  ],
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0"
  }
}
