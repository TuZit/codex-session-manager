{
  "name": "codex-session-manager",
  "version": "0.1.0",
  "description": "A CLI for inspecting and safely managing local Codex sessions.",
  "type": "module",
  "bin": {
    "codex-session-manager": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "codex",
    "cli",
    "sessions"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0"
  }
}
